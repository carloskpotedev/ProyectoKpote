@{
    ViewData["Title"] = "Login";
}

<div class="d-flex align-items-center justify-content-center" style="min-height: 80vh;">
    <div class="w-100" style="max-width: 400px;">

        <div class="card p-4 shadow-sm mb-4">

            <div class="btn-group mb-4" role="group" aria-label="Tipo de documento">
                <button type="button" class="btn btn-secondary">DNI</button>
                <button type="button" class="btn btn-outline-secondary">CE</button>
            </div>

            <form method="post" asp-controller="Login" asp-action="Index" novalidate>
                <div class="mb-3">
                    <label for="nombreUsuario" class="form-label">Usuario</label>
                    <div class="input-group has-validation @(ViewBag.ErrorUsuario != null ? "campo-invalido" : "")">
                        <span class="input-group-text border-0"><i class="fa-regular fa-user"></i></span>
                        <input name="nombreUsuario" id="nombreUsuario" type="text" class="form-control border-0"
                               placeholder="Ingresar Usuario" value="@ViewBag.NombreUsuarioValor">
                    </div>
                    @if (ViewBag.ErrorUsuario != null)
                    {
                        <div class="feedback-invalido">
                            <i class="fa-solid fa-circle-exclamation"></i>
                            <span>@ViewBag.ErrorUsuario</span>
                        </div>
                    }
                </div>

                <div class="mb-3">
                    <label for="password" class="form-label">Contraseña</label>
                    <div class="input-group has-validation @(ViewBag.ErrorPassword != null ? "campo-invalido" : "")">
                        <span class="input-group-text border-0"><i class="fa-solid fa-lock"></i></span>
                        <input name="password" id="password" type="password" class="form-control border-0"
                               placeholder="Ingresar Contraseña">
                        <button class="btn btn-outline-secondary" type="button" id="togglePassword">
                            <i class="fa-regular fa-eye" id="eyeIcon"></i>
                        </button>
                    </div>
                    @if (ViewBag.ErrorPassword != null)
                    {
                        <div class="feedback-invalido">
                            <i class="fa-solid fa-circle-exclamation"></i>
                            <span>@ViewBag.ErrorPassword</span>
                        </div>
                    }
                </div>

                <div class="mb-3">
                    <a href="#" style="text-decoration: none;">¿Olvidaste tu contraseña?</a>
                </div>

                <div class="d-grid">
                    <button type="submit" class="btn btn-primary">Ingresar</button>
                </div>
            </form>
        </div>

        <div class="card p-3 shadow-sm">
            <div class="d-flex align-items-center">
                <div class="me-3">
                    <img src="../images/soporte.png" class="img-fluid" width="80" alt="Soporte">
                </div>
                <div>
                    <p class="mb-0">
                        ¿Necesitas ayuda?, <a href="#" style="text-decoration: none;">contacte con el área de
                        soporte.</a>
                    </p>
                </div>
            </div>
        </div>

    </div>
</div>


@if (TempData["MensajeInactividad"] != null)
{
    <div class="position-fixed top-0 start-50 translate-middle-x p-3"
         style="z-index: 1050; width: 100%; max-width: 900px; pointer-events: none;">
        <div id="toastInactividad" class="toast toast-inactividad shadow-lg w-100" role="alert" aria-live="assertive"
             aria-atomic="true" style="pointer-events: auto;">
            <div class="d-flex align-items-center p-3">
                <div class="flex-shrink-0 me-3">
                    <i class="fa-solid fa-circle-exclamation fa-xl"></i>
                </div>
                <div class="toast-body flex-grow-1 text-center">
                    @TempData["MensajeInactividad"]
                </div>
                <button type="button" class="btn-close btn-close-white ms-3" data-bs-dismiss="toast"
                        aria-label="Close"></button>
            </div>
            <div class="progress-timer">
                <div id="progressBarTimer" class="progress-bar-timer" style="width: 100%;"></div>
            </div>
        </div>
    </div>
}

@section Scripts {
    <script>
        const togglePassword = document.querySelector('#togglePassword');
        const password = document.querySelector('#password');
        const eyeIcon = document.querySelector('#eyeIcon');

        togglePassword.addEventListener('click', function (e) {
            const type = password.getAttribute('type') === 'password' ? 'text' : 'password';
            password.setAttribute('type', type);

            eyeIcon.classList.toggle('fa-eye');
            eyeIcon.classList.toggle('fa-eye-slash');
        });
    </script>

    @if (TempData["MensajeInactividad"] != null)
    {
        <script>
            document.addEventListener('DOMContentLoaded', function () {
                var toastEl = document.getElementById('toastInactividad');
                if (toastEl) {
                    var progressBar = document.getElementById('progressBarTimer');
                    var duration = 10000; // 10 segundos
                    var intervalTime = 50; // actualizar cada 50ms para fluidez
                    var startTime = Date.now();
                    var timerId;

                    function updateProgress() {
                        var elapsed = Date.now() - startTime;
                        var remaining = Math.max(0, duration - elapsed);
                        var percent = (remaining / duration) * 100;

                        if (progressBar) {
                            progressBar.style.width = percent + '%';
                        }

                        // Si el tiempo se acabó
                        if (remaining <= 0) {
                            clearInterval(timerId);

                            if (toast) {
                                toast.hide();
                            }
                        }
                    }

                    var toast = new bootstrap.Toast(toastEl, {
                        delay: duration,
                        animation: true,
                        autohide: true
                    });

                    toastEl.addEventListener('hidden.bs.toast', function () {
                        if (timerId) {
                            clearInterval(timerId);
                        }
                    });

                    toast.show();

                    startTime = Date.now();
                    timerId = setInterval(updateProgress, intervalTime);
                    updateProgress();
                }
            });
        </script>
    }
}